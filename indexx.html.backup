<style>
  :root {
    --white: #ffffff;
    --off-white: #fdf6fb;
    --pink-light: #fce0ef;
    --pink: #f0186e;
    --pink-soft: #ff6db0;
    --pink-pale: #ffe0f0;
    --pink-deep: #c4105a;
    --dark: #180a10;
    --muted: #9e6585;
    --shadow-pink: 0 8px 40px rgba(240,24,110,0.13);
    --shadow-pink-hover: 0 16px 60px rgba(240,24,110,0.24);
    --radius-card: 20px;
    --radius-pill: 100px;
    /* z-index scale */
    --z-nav: 1000;
    --z-menu: 999;
    --z-modal: 9999;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--dark);
    background: var(--white);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, .logo { font-family: 'Syne', sans-serif; }

  /* Focus visible — доступность клавиатуры */
  :focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* Уважаем prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .fade-up {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: var(--z-nav);
    background: rgba(255,255,255,0.93);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(240,24,110,0.1);
    box-shadow: 0 2px 24px rgba(240,24,110,0.07);
  }

  .nav-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--dark);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .logo span { color: var(--pink); font-size: 24px; line-height: 1; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--dark); }

  .nav-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

  /* Убираем инлайн-стиль — выносим в CSS */
  .nav-auth-out { display: flex; gap: 8px; align-items: center; }

  .btn-ghost {
    background: none;
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--dark);
    cursor: pointer;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-ghost:hover { background: var(--pink-light); }

  /* Базовая кнопка (DRY) */
  .btn-base {
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
  }

  .btn-pink {
    background: var(--pink);
    color: var(--white);
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 9px 20px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 4px 18px rgba(240,24,110,0.32);
    white-space: nowrap;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .btn-pink:hover {
    background: var(--pink-deep);
    box-shadow: 0 6px 28px rgba(240,24,110,0.45);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: none;
    border: 2px solid var(--dark);
    color: var(--dark);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 13px 28px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .btn-outline:hover {
    border-color: var(--pink);
    color: var(--pink);
    transform: translateY(-1px);
  }

  .btn-pink-lg {
    background: var(--pink);
    color: var(--white);
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    padding: 15px 36px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 6px 30px rgba(240,24,110,0.38);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .btn-pink-lg:hover {
    background: var(--pink-deep);
    box-shadow: 0 10px 40px rgba(240,24,110,0.52);
    transform: translateY(-2px);
  }

  /* Mobile menu */
  .mobile-menu-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-menu);
    background: rgba(24,10,16,0.5);
    backdrop-filter: blur(4px);
  }

  .mobile-menu-overlay.open { display: block; }

  .mobile-menu {
    position: fixed;
    top: 64px; left: 0; right: 0;
    z-index: var(--z-nav);
    background: var(--white);
    border-bottom: 1px solid rgba(240,24,110,0.1);
    box-shadow: 0 16px 40px rgba(0,0,0,0.12);
    padding: 20px 24px 28px;
    display: none;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-menu.open { display: flex; }

  .mobile-menu a, .mobile-menu button {
    text-decoration: none;
    color: var(--dark);
    font-size: 16px;
    font-weight: 500;
    padding: 12px 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    text-align: left;
    border-bottom: 1px solid rgba(240,24,110,0.07);
  }

  .mobile-menu .mob-buy {
    margin-top: 12px;
    background: var(--pink);
    color: var(--white);
    border-radius: var(--radius-pill);
    padding: 13px 24px;
    font-weight: 700;
    text-align: center;
    border: none;
    box-shadow: 0 4px 18px rgba(240,24,110,0.32);
    cursor: pointer;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
    background: none;
    border: none;
    flex-shrink: 0;
  }

  .hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: var(--dark);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .user-nav { display: none; align-items: center; gap: 10px; }
  .user-nav.visible { display: flex; }
  .user-name { font-size: 13px; font-weight: 600; color: var(--dark); max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .sub-badge {
    font-size: 11px; font-weight: 700;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    background: var(--pink-light);
    color: var(--pink);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--white);
    padding: 100px 24px 60px;
    position: relative;
    overflow: hidden;
  }

  .hero-blob { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0; }
  .hero-blob-1 { width: 700px; height: 700px; background: radial-gradient(circle, rgba(240,24,110,0.14) 0%, transparent 70%); top: -150px; right: -200px; }
  .hero-blob-2 { width: 450px; height: 450px; background: radial-gradient(circle, rgba(255,109,176,0.12) 0%, transparent 70%); bottom: 0; left: -120px; }

  .hero-inner {
    max-width: 1160px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--pink-light);
    color: var(--pink);
    font-size: 12px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    margin-bottom: 24px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-title {
    font-size: clamp(52px, 8vw, 100px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -3px;
    margin-bottom: 24px;
  }

  .hero-title .line1 { color: var(--dark); display: block; }
  .hero-title .line2 {
    display: block;
    background: linear-gradient(130deg, var(--pink) 0%, var(--pink-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 17px;
    line-height: 1.65;
    color: var(--muted);
    font-weight: 300;
    margin-bottom: 40px;
    max-width: 460px;
  }

  .hero-buttons { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }

  .hero-tg-note {
    margin-top: 20px;
    font-size: 13px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .hero-tg-note a { color: var(--pink); text-decoration: none; font-weight: 600; }
  .hero-tg-note a:hover { text-decoration: underline; }

  .hero-visual { display: flex; justify-content: center; align-items: center; }
  .hero-svg-wrap { width: 100%; max-width: 460px; aspect-ratio: 1; }

  /* will-change только на анимируемые группы */
  .hero-svg-wrap .anim-g { will-change: transform; }

  .hero-stats { max-width: 1160px; width: 100%; margin-top: 64px; position: relative; z-index: 1; }

  .stats-bar {
    background: var(--off-white);
    border: 1px solid rgba(240,24,110,0.12);
    border-radius: 20px;
    padding: 24px 40px;
    display: flex;
    justify-content: space-around;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .stat-item { text-align: center; }
  .stat-value { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; color: var(--dark); display: block; }
  .stat-label { font-size: 12px; color: var(--muted); margin-top: 3px; display: block; }
  .stat-divider { width: 1px; height: 44px; background: rgba(240,24,110,0.15); flex-shrink: 0; }

  /* ─── SECTIONS ─── */
  .section-inner { max-width: 1160px; margin: 0 auto; position: relative; z-index: 1; }
  .section-label { font-size: 12px; font-weight: 700; color: var(--pink); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 14px; display: block; }
  .section-title { font-size: clamp(30px, 5vw, 50px); font-weight: 800; letter-spacing: -1.5px; line-height: 1.05; margin-bottom: 48px; }

  /* ─── FEATURES ─── */
  .features {
    background: var(--pink-light);
    padding: 110px 24px;
    position: relative;
    overflow: hidden;
  }

  .features-blob {
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.45) 0%, transparent 70%);
    top: -100px; right: -100px;
    pointer-events: none;
  }

  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  .feature-card {
    background: var(--white);
    border-radius: var(--radius-card);
    padding: 36px 30px;
    box-shadow: var(--shadow-pink);
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--pink), var(--pink-soft));
    border-radius: 20px 20px 0 0;
  }

  .feature-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-pink-hover); }
  .feature-icon { font-size: 42px; margin-bottom: 18px; display: block; line-height: 1; }
  .feature-title { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .feature-desc { font-size: 14px; line-height: 1.7; color: var(--muted); }

  /* ─── SERVERS ─── */
  .servers { background: var(--white); padding: 110px 24px; }

  .servers-grid { display: flex; flex-direction: column; gap: 12px; }

  .server-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--off-white);
    border: 2px solid transparent;
    border-radius: 16px;
    padding: 18px 26px;
    transition: all 0.25s;
    flex-wrap: wrap;
    gap: 12px;
  }

  .server-card:hover { border-color: var(--pink); background: var(--white); box-shadow: 0 4px 24px rgba(240,24,110,0.1); }

  .server-card.cs { opacity: 0.5; }
  .server-card.cs:hover { border-color: transparent; background: var(--off-white); box-shadow: none; }

  .server-left { display: flex; align-items: center; gap: 16px; }
  .server-flag { font-size: 30px; line-height: 1; }
  .server-name { font-weight: 700; font-size: 15px; }
  .server-region { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .server-right { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; }
  .sv { font-weight: 700; font-size: 14px; font-family: 'Syne', sans-serif; }
  .sl { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }
  .pg { color: #22c55e; }
  .ping-badge { background: #dcfce7; color: #16a34a; font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: var(--radius-pill); white-space: nowrap; }
  .soon-badge { background: var(--pink-light); color: var(--pink); font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: var(--radius-pill); white-space: nowrap; }

  /* ─── PRICING ─── */
  .pricing {
    background: linear-gradient(145deg, #f0186e 0%, #b5105a 45%, #8c0d46 100%);
    padding: 110px 24px;
    position: relative;
    overflow: hidden;
  }

  .pricing::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    top: -200px; right: -200px;
    pointer-events: none;
  }

  .pricing .section-title { color: var(--white); }
  .pricing .section-label { color: rgba(255,255,255,0.6); }

  .pricing-plans-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .plan-card {
    background: rgba(255,255,255,0.1);
    border: 1.5px solid rgba(255,255,255,0.18);
    border-radius: 20px;
    padding: 28px 20px;
    color: var(--white);
    position: relative;
    transition: all 0.3s;
    backdrop-filter: blur(10px);
    text-align: center;
  }

  .plan-card:hover { background: rgba(255,255,255,0.16); transform: translateY(-3px); }

  .plan-card.best {
    background: var(--white);
    border-color: var(--white);
    color: var(--dark);
    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    transform: scale(1.04);
  }

  .plan-card.best:hover { transform: scale(1.04) translateY(-3px); }

  .best-badge {
    position: absolute;
    top: -13px; left: 50%;
    transform: translateX(-50%);
    background: var(--pink);
    color: var(--white);
    font-size: 11px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .plan-period { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.65; margin-bottom: 12px; }
  .plan-card.best .plan-period { color: var(--muted); opacity: 1; }

  .plan-price { font-family: 'Syne', sans-serif; font-size: 38px; font-weight: 800; letter-spacing: -1.5px; line-height: 1; margin-bottom: 3px; }

  .plan-per { font-size: 11px; opacity: 0.5; margin-bottom: 2px; }
  .plan-total { font-size: 12px; opacity: 0.45; margin-bottom: 5px; }
  .plan-card.best .plan-per, .plan-card.best .plan-total { color: var(--muted); }

  .plan-save {
    display: inline-block;
    font-size: 11px; font-weight: 700;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.18);
    color: var(--white);
    min-height: 22px;
  }

  .plan-card.best .plan-save { background: var(--pink-light); color: var(--pink); }
  .plan-save.inv { visibility: hidden; }

  .btn-plan-buy {
    width: 100%;
    padding: 11px;
    border-radius: var(--radius-pill);
    border: 1.5px solid rgba(255,255,255,0.5);
    background: none;
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.25s;
    margin-top: 16px;
    display: block;
    text-align: center;
  }

  .btn-plan-buy:hover { background: rgba(255,255,255,0.15); border-color: var(--white); }

  .btn-plan-buy.bb {
    background: var(--pink);
    border-color: var(--pink);
    color: var(--white);
    box-shadow: 0 6px 24px rgba(240,24,110,0.4);
  }

  .btn-plan-buy.bb:hover { background: var(--pink-deep); transform: translateY(-1px); }

  .pricing-inc {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 26px 30px;
    backdrop-filter: blur(10px);
    margin-bottom: 14px;
  }

  .pricing-inc-title {
    font-family: 'Syne', sans-serif;
    font-size: 12px; font-weight: 700;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .pricing-inc-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    list-style: none;
  }

  .pricing-inc-list li {
    font-size: 14px;
    color: rgba(255,255,255,0.9);
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.4;
  }

  .pricing-inc-list li::before {
    content: '✓';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px; height: 18px; min-width: 18px;
    background: rgba(255,255,255,0.18);
    border-radius: 50%;
    font-size: 10px; font-weight: 700;
    flex-shrink: 0;
    color: var(--white);
    margin-top: 1px;
  }

  .pricing-refund-note {
    margin-top: 14px;
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    text-align: center;
    line-height: 1.5;
  }

  /* ─── REFERRALS ─── */
  .referrals {
    background: var(--white);
    padding: 96px 24px;
    border-top: 1px solid rgba(240,24,110,0.08);
    position: relative;
    overflow: hidden;
  }

  .referrals::before {
    content: '';
    position: absolute;
    width: 520px; height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(240,24,110,0.1), transparent 70%);
    right: -160px; top: -180px;
    pointer-events: none;
  }

  .ref-card {
    background: var(--off-white);
    border: 1px solid rgba(240,24,110,0.12);
    border-radius: 24px;
    padding: 30px;
    box-shadow: var(--shadow-pink);
    margin-top: 34px;
  }

  .ref-rules {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 22px;
  }

  .ref-rule {
    background: var(--white);
    border-radius: 18px;
    padding: 18px;
    border: 1px solid rgba(240,24,110,0.1);
  }

  .ref-rule strong { display: block; font-size: 16px; margin-bottom: 6px; color: var(--dark); }
  .ref-rule span { display: block; font-size: 13px; line-height: 1.55; color: var(--muted); }

  .ref-auth-box {
    background: var(--white);
    border-radius: 18px;
    padding: 22px;
    text-align: center;
    border: 1px dashed rgba(240,24,110,0.32);
  }

  .ref-link-box {
    display: none;
    background: var(--white);
    border-radius: 18px;
    padding: 22px;
    border: 1px solid rgba(240,24,110,0.1);
  }

  .ref-link-row { display: flex; gap: 10px; margin: 14px 0; }
  .ref-link-row input {
    flex: 1;
    border: 1.5px solid var(--pink-light);
    border-radius: var(--radius-pill);
    padding: 12px 16px;
    color: var(--dark);
    font-family: 'DM Sans', sans-serif;
    min-width: 0;
  }

  .ref-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-top: 16px;
  }

  .ref-stat {
    background: var(--off-white);
    border-radius: 14px;
    padding: 14px;
    text-align: center;
  }

  .ref-stat strong { display: block; font-family: 'Syne', sans-serif; font-size: 24px; color: var(--dark); }
  .ref-stat span { display: block; font-size: 11px; color: var(--muted); margin-top: 2px; }

  /* ─── DELIVERY ─── */
  .delivery {
    background: var(--off-white);
    padding: 90px 24px;
    border-top: 1px solid rgba(240,24,110,0.08);
  }

  .delivery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 44px;
  }

  .del-card {
    background: var(--white);
    border-radius: 16px;
    padding: 26px 24px;
    border: 1px solid rgba(240,24,110,0.1);
  }

  .del-icon { font-size: 30px; margin-bottom: 14px; display: block; }
  .del-title { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .del-text { font-size: 13px; line-height: 1.65; color: var(--muted); }
  .del-text a { color: var(--pink); text-decoration: none; }
  .del-text a:hover { text-decoration: underline; }

  /* ─── RETURN POLICY ─── */
  .return-policy {
    background: var(--white);
    padding: 90px 24px;
    border-top: 1px solid rgba(240,24,110,0.08);
  }

  .return-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 44px;
  }

  .ret-card { border-radius: 16px; padding: 26px 24px; }
  .ret-card.yes { background: #f0fdf4; border: 1.5px solid #86efac; }
  .ret-card.no { background: #fff1f2; border: 1.5px solid #fca5a5; }

  .ret-title { font-size: 15px; font-weight: 700; margin-bottom: 14px; }
  .ret-card.yes .ret-title { color: #15803d; }
  .ret-card.no .ret-title { color: #b91c1c; }

  .ret-card ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .ret-card ul li { font-size: 13px; line-height: 1.5; color: var(--dark); display: flex; align-items: flex-start; gap: 8px; }
  .ret-card ul li::before { flex-shrink: 0; margin-top: 1px; font-weight: 700; }
  .ret-card.yes ul li::before { content: '✓'; color: #16a34a; }
  .ret-card.no ul li::before { content: '✗'; color: #dc2626; }

  .ret-contact {
    margin-top: 24px;
    padding: 18px 22px;
    background: var(--pink-light);
    border-radius: 14px;
    font-size: 14px;
    color: var(--dark);
    line-height: 1.65;
  }

  .ret-contact a { color: var(--pink); text-decoration: none; font-weight: 600; }
  .ret-contact a:hover { text-decoration: underline; }

  /* ─── CONTACTS ─── */
  .contacts { background: var(--pink-light); padding: 90px 24px; }

  .contacts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 44px;
  }

  .con-card {
    background: var(--white);
    border-radius: 16px;
    padding: 22px 20px;
    box-shadow: var(--shadow-pink);
  }

  .con-label { font-size: 11px; font-weight: 700; color: var(--pink); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; display: block; }
  .con-value { font-size: 14px; font-weight: 600; color: var(--dark); text-decoration: none; display: block; word-break: break-word; }
  .con-value:hover { color: var(--pink); }
  .con-note { font-size: 12px; color: var(--muted); margin-top: 4px; }

  /* ─── FAQ ─── */
  .faq { background: var(--white); padding: 110px 24px; }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 760px;
    margin: 0 auto;
  }

  .faq-item {
    border: 1.5px solid rgba(240,24,110,0.12);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.25s;
  }

  .faq-item.open { border-color: var(--pink); }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    padding: 20px 22px;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 600;
    color: var(--dark);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    transition: background 0.2s;
  }

  .faq-item.open .faq-q { background: var(--off-white); }

  .faq-icon {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: var(--pink-light);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all 0.3s;
    font-size: 16px;
    color: var(--pink);
    pointer-events: none;
  }

  .faq-item.open .faq-icon { background: var(--pink); color: var(--white); transform: rotate(45deg); }

  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
    padding: 0 22px;
    font-size: 14px; line-height: 1.75;
    color: var(--muted);
  }

  .faq-item.open .faq-a { max-height: 320px; padding: 0 22px 20px; }
  .faq-a a { color: var(--pink); text-decoration: none; }
  .faq-a a:hover { text-decoration: underline; }

  /* ─── FOOTER ─── */
  footer {
    background: var(--dark);
    color: rgba(255,255,255,0.85);
    padding: 72px 24px 44px;
  }

  .footer-inner { max-width: 1160px; margin: 0 auto; }

  .footer-top {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 44px;
  }

  .footer-brand .logo { color: var(--white); font-size: 22px; margin-bottom: 14px; display: inline-flex; }
  .footer-brand p { font-size: 13px; line-height: 1.7; color: rgba(255,255,255,0.45); max-width: 260px; }

  .footer-brand .legal-note {
    margin-top: 14px;
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    line-height: 1.75;
  }

  .footer-col h4 {
    font-family: 'Syne', sans-serif;
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }

  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .footer-col a {
    text-decoration: none;
    color: rgba(255,255,255,0.6);
    font-size: 13px;
    transition: color 0.2s;
    cursor: pointer;
    background: none;
    border: none;
    font-family: 'DM Sans', sans-serif;
    padding: 0;
    text-align: left;
  }

  .footer-col a:hover { color: var(--pink-soft); }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-bottom p { font-size: 12px; color: rgba(255,255,255,0.3); }
  .footer-bottom a { color: var(--pink-soft); text-decoration: none; transition: color 0.2s; cursor: pointer; }
  .footer-bottom a:hover { color: var(--white); }

  /* ─── MODALS ─── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background: rgba(24,10,16,0.55);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--white);
    border-radius: 24px;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 40px 120px rgba(240,24,110,0.17);
    position: relative;
    animation: modalIn 0.32s cubic-bezier(0.34,1.56,0.64,1);
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-close {
    position: absolute;
    top: 18px; right: 18px;
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--off-white);
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    color: var(--muted);
    transition: all 0.2s;
    z-index: 1;
  }

  .modal-close:hover { background: var(--pink-light); color: var(--pink); }

  .modal-body { padding: 44px 40px; }
  .modal-body h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 6px; }
  .modal-body .msub { font-size: 13px; color: var(--muted); margin-bottom: 24px; }
  .modal-body .msub a { color: var(--pink); text-decoration: none; }

  .form-group { margin-bottom: 14px; }
  .form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--dark); margin-bottom: 6px; }
  .form-group input {
    width: 100%;
    padding: 11px 15px;
    border: 1.5px solid rgba(240,24,110,0.15);
    border-radius: 11px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--dark);
    background: var(--off-white);
    outline: none;
    transition: border-color 0.2s;
  }

  .form-group input:focus { border-color: var(--pink); background: var(--white); }
  .form-group input::placeholder { color: var(--muted); }
  .form-hint { font-size: 12px; color: var(--muted); margin-top: 6px; line-height: 1.35; }

  .btn-submit {
    width: 100%;
    padding: 13px;
    background: var(--pink);
    color: var(--white);
    border: none;
    border-radius: var(--radius-pill);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 700;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 6px 28px rgba(240,24,110,0.35);
    margin-top: 6px;
  }

  .btn-submit:hover { background: var(--pink-deep); transform: translateY(-1px); }
  .btn-submit:disabled { opacity: 0.65; cursor: not-allowed; transform: none; }

  .mswitch { text-align: center; margin-top: 16px; font-size: 13px; color: var(--muted); }
  .mswitch a { color: var(--pink); font-weight: 600; text-decoration: none; cursor: pointer; }

  .alert { padding: 10px 14px; border-radius: 9px; font-size: 13px; margin-bottom: 14px; display: none; }
  .alert.error { background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; display: block; }
  .alert.success { background: #dcfce7; color: #15803d; border: 1px solid #86efac; display: block; }

  .modal-scroll { max-height: 60vh; overflow-y: auto; padding-right: 6px; }
  .modal-scroll::-webkit-scrollbar { width: 3px; }
  .modal-scroll::-webkit-scrollbar-thumb { background: var(--pink-light); border-radius: 4px; }
  .modal-scroll h3 { font-size: 14px; font-weight: 700; margin: 18px 0 8px; color: var(--dark); }
  .modal-scroll p { font-size: 13px; line-height: 1.7; color: var(--muted); margin-bottom: 8px; }

  /* Payment modal */
  .pay-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }

  .pay-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 13px 20px;
    border-radius: var(--radius-pill);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 700;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    border: none;
    width: 100%;
  }

  .pay-btn.lava { background: var(--pink); color: var(--white); box-shadow: 0 6px 24px rgba(240,24,110,0.35); }
  .pay-btn.lava:hover { background: var(--pink-deep); transform: translateY(-1px); }
  .pay-btn.lava:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

  .pay-legal { font-size: 12px; color: var(--muted); text-align: center; margin-top: 8px; line-height: 1.5; }
  .pay-legal a { color: var(--pink); cursor: pointer; text-decoration: none; }
  .pay-legal a:hover { text-decoration: underline; }

  /* Profile modal helpers */
  .profile-sub-block {
    background: var(--off-white);
    border: 1px solid rgba(240,24,110,0.12);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .profile-sub-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .profile-sub-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--pink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .profile-expires-row { font-size: 13px; color: var(--muted); margin-bottom: 6px; }
  .profile-url-block { margin-bottom: 16px; }
  .profile-url-label { font-size: 12px; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
  .profile-url-row { display: flex; gap: 8px; }
  .profile-url-row input {
    flex: 1;
    border: 1.5px solid var(--pink-light);
    border-radius: var(--radius-pill);
    padding: 10px 14px;
    font-family: monospace;
    font-size: 12px;
    color: var(--dark);
    background: var(--off-white);
    min-width: 0;
  }
  .profile-inactive-block {
    background: var(--pink-light);
    border-radius: 16px;
    padding: 20px;
    text-align: center;
    margin-bottom: 16px;
  }
  .profile-inactive-icon { font-size: 32px; margin-bottom: 8px; }
  .profile-inactive-title { font-weight: 700; margin-bottom: 6px; }
  .profile-inactive-sub { font-size: 13px; color: var(--muted); }

  /* ─── ANIMATIONS ─── */
  @keyframes float1 { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-18px) rotate(3deg); } }
  @keyframes float2 { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(14px) rotate(-2deg); } }
  @keyframes float3 { 0%, 100% { transform: translateY(0); } 33% { transform: translateY(-10px); } 66% { transform: translateY(7px); } }
  @keyframes pulse-glow { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }

  .fade-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s cubic-bezier(0.4,0,0.2,1), transform 0.65s cubic-bezier(0.4,0,0.2,1);
  }

  .fade-up.visible { opacity: 1; transform: translateY(0); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-visual { display: none; }
    .hero-sub { margin: 0 auto 36px; }
    .hero-buttons { justify-content: center; }
    .hero-tg-note { justify-content: center; }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .pricing-plans-grid { grid-template-columns: 1fr 1fr; }
    .plan-card.best { transform: scale(1); }
    .plan-card.best:hover { transform: translateY(-3px); }
    .pricing-inc-list { grid-template-columns: 1fr 1fr; }
    .ref-rules { grid-template-columns: 1fr; }
    .ref-stats { grid-template-columns: 1fr 1fr; }
    .delivery-grid { grid-template-columns: 1fr; gap: 14px; }
    .return-grid { grid-template-columns: 1fr; }
    .contacts-grid { grid-template-columns: 1fr 1fr; }
    .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .hero { padding: 84px 20px 48px; }
    .hero-title { letter-spacing: -2px; }
    .stats-bar { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; padding: 20px; }
    .stat-divider { display: none; }
    .features { padding: 80px 20px; }
    .features-grid { grid-template-columns: 1fr; gap: 14px; }
    .servers { padding: 80px 20px; }
    .server-card { padding: 14px 18px; }
    .pricing { padding: 80px 20px; }
    .pricing-plans-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
    .plan-card { padding: 22px 14px; }
    .plan-price { font-size: 30px; }
    .pricing-inc-list { grid-template-columns: 1fr; }
    .pricing-inc { padding: 22px 18px; }
    .delivery, .return-policy, .contacts { padding: 64px 20px; }
    .contacts-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .faq { padding: 80px 20px; }
    footer { padding: 56px 20px 36px; }
    .footer-top { grid-template-columns: 1fr; gap: 28px; }
    .modal-body { padding: 28px 20px; }
    .modal { border-radius: 20px; }
    .section-title { letter-spacing: -1px; }
    /* Мобильные модалки — снизу экрана */
    .modal-overlay { padding: 0; align-items: flex-end; }
    .modal {
      border-radius: 24px 24px 0 0;
      max-width: 100% !important;
      max-height: 92dvh;
      overflow-y: auto;
    }
    .modal-close { top: 14px; right: 14px; }
    /* Ref link */
    .ref-link-row { flex-direction: column; }
    /* Profile URL row на мобилке */
    .profile-url-row { flex-direction: column; }
    .profile-url-row input { font-size: 11px; }
  }

  @media (max-width: 480px) {
    .hero-buttons { flex-direction: column; align-items: stretch; }
    .hero-buttons .btn-pink-lg, .hero-buttons .btn-outline { justify-content: center; }
    .pricing-plans-grid { grid-template-columns: 1fr; }
    .contacts-grid { grid-template-columns: 1fr; }
    .btn-ghost { padding: 7px 10px; font-size: 13px; }
    .btn-pink { padding: 8px 14px; font-size: 13px; }
    /* Минимум 48px для тач-таргетов */
    .btn-plan-buy { min-height: 48px; }
    .faq-q { min-height: 48px; }
    .form-group input { font-size: 16px; /* iOS zoom prevention */ }
    .btn-submit { min-height: 50px; font-size: 16px; }
  }

  /* ─── LOGIN MODAL TABS ─── */
  .auth-tabs {
    display: flex;
    gap: 0;
    border-radius: 12px;
    background: var(--off-white);
    padding: 4px;
    margin-bottom: 22px;
  }
  .auth-tab {
    flex: 1;
    padding: 9px 12px;
    border: none;
    background: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    border-radius: 9px;
    transition: all 0.2s;
  }
  .auth-tab.active {
    background: var(--white);
    color: var(--dark);
    box-shadow: 0 2px 8px rgba(0,0,0,0.09);
  }
  .auth-panel { display: none; }
  .auth-panel.active { display: block; }
</style>
</head>
<body>

<nav role="navigation" aria-label="Основная навигация">
  <div class="nav-inner">
    <a href="#" class="logo" aria-label="ZephyrionVPN — на главную">ZEPHYRION<span aria-hidden="true">·</span></a>
    <ul class="nav-links">
      <li><a href="#features">Возможности</a></li>
      <li><a href="#servers">Серверы</a></li>
      <li><a href="#pricing">Тарифы</a></li>
      <li><a href="#referrals">Рефералы</a></li>
