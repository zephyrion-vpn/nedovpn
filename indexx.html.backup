<script>
  // ─── CONFIG ───
  const API_BASE = 'https://zephyrion.ru/api';
  const TOKEN_KEY = 'zeph_token';
  // FIX: добавляем ключ для refresh_token
  const REFRESH_KEY = 'zeph_refresh';
  const REF_KEY = 'zeph_ref';
  const REF_CLIENT_KEY = 'zeph_ref_client';

  const PLANS = {
    '1m':  { label: '1 месяц · 89 ₽',     sum: 89  },
    '3m':  { label: '3 месяца · 249 ₽',   sum: 249  },
    '6m':  { label: '6 месяцев · 474 ₽',  sum: 474  },
    '12m': { label: '12 месяцев · 900 ₽', sum: 900  }
  };

  let currentPlan = '1m';
  let currentReferralCode = '';
  let currentUser = null;
  let currentSub = null;
  let isPaymentPending = false;

  // FIX: флаг и промис для одного refresh-запроса на всех параллельных 401
  let isRefreshing = false;
  let refreshPromise = null;

  // ─── REFERRAL CLIENT ID ───
  function getReferralClientId() {
    let id = localStorage.getItem(REF_CLIENT_KEY);
    if (!id) {
      const bytes = new Uint8Array(16);
      if (window.crypto && window.crypto.getRandomValues) {
        window.crypto.getRandomValues(bytes);
        id = Array.from(bytes, b => b.toString(16).padStart(2, '0')).join('');
      } else {
        id = Date.now().toString(36) + Math.random().toString(36).slice(2);
      }
      localStorage.setItem(REF_CLIENT_KEY, id);
    }
    return id;
  }

  // ─── TELEGRAM MINI APP ───
  const tg = window.Telegram?.WebApp;
  if (tg) { tg.ready(); tg.expand(); }

  async function doTgAuth() {
    if (!tg || !tg.initData) return false;
    try {
      const { ok, data } = await apiFetch('/auth/telegram', {
        method: 'POST',
        body: JSON.stringify({
          init_data: tg.initData,
          referral_code: getStoredReferralCode(),
          client_referral_id: getReferralClientId()
        })
      });
      if (ok && data.access_token) {
        // FIX: сохраняем оба токена
        setTokens(data.access_token, data.refresh_token || null);
        await loadUserData();
        return true;
      }
      return false;
    } catch { return false; }
  }

  // ─── FOCUS TRAP ───
  function trapFocus(overlayEl) {
    const modal = overlayEl.querySelector('.modal');
    if (!modal) return;
    const focusable = modal.querySelectorAll(
      'button:not([disabled]), [href], input:not([disabled]), select, textarea, [tabindex]:not([tabindex="-1"])'
    );
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    setTimeout(() => first.focus(), 50);
    function handler(e) {
      if (e.key !== 'Tab') return;
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
    overlayEl._trapHandler = handler;
    overlayEl.addEventListener('keydown', handler);
  }

  function releaseFocus(overlayEl) {
    if (overlayEl._trapHandler) {
      overlayEl.removeEventListener('keydown', overlayEl._trapHandler);
      delete overlayEl._trapHandler;
    }
  }

  // ─── MODALS ───
  function openModal(id) {
    const overlay = document.getElementById('modal-' + id);
    if (!overlay) return;
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    trapFocus(overlay);
  }

  function closeModal(id) {
    const overlay = document.getElementById('modal-' + id);
    if (!overlay) return;
    overlay.classList.remove('open');
    releaseFocus(overlay);
    if (!document.querySelector('.modal-overlay.open')) {
      document.body.style.overflow = '';
    }
    const a = document.getElementById(id + '-alert');
    if (a) { a.className = 'alert'; a.textContent = ''; }
  }

  function switchModal(f, t) { closeModal(f); setTimeout(() => openModal(t), 180); }

  // FIX: закрытие по клику на оверлей только если mousedown начался НА оверлее,
  // а не внутри модалки — drag outside не закрывает окно
  document.querySelectorAll('.modal-overlay').forEach(o => {
    let mousedownOnOverlay = false;
    o.addEventListener('mousedown', function(e) {
      mousedownOnOverlay = (e.target === this);
    });
    o.addEventListener('click', function(e) {
      if (mousedownOnOverlay && e.target === this) {
        closeModal(this.id.replace('modal-', ''));
      }
      mousedownOnOverlay = false;
    });
    // Touch: тот же принцип
    o.addEventListener('touchstart', function(e) {
      mousedownOnOverlay = (e.target === this);
    }, { passive: true });
  });

  // Закрытие по Escape
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    const openOverlay = document.querySelector('.modal-overlay.open');
    if (openOverlay) closeModal(openOverlay.id.replace('modal-', ''));
  });

  // ─── AUTH TABS (комбинированная модалка вход/регистрация) ───
  // FIX: переключение вкладок внутри одной модалки «Добро пожаловать»
  function switchAuthTab(tab) {
    document.querySelectorAll('.auth-tab').forEach(btn => {
      const isActive = btn.id === 'tab-' + tab;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', String(isActive));
    });
    document.querySelectorAll('.auth-panel').forEach(panel => {
      panel.classList.toggle('active', panel.id === 'auth-panel-' + tab);
    });
    // Сбрасываем алерты при переключении
    ['login-alert', 'reg-alert'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.className = 'alert'; el.textContent = ''; }
    });
  }

  // FIX: openModal('register') → открываем login-модалку на вкладке «Регистрация»
  function openRegisterModal() {
    openModal('login');
    setTimeout(() => switchAuthTab('reg'), 50);
  }

  // ─── MOBILE MENU ───
  let menuOpen = false;

  function toggleMenu() {
    menuOpen = !menuOpen;
    document.getElementById('mobile-menu').classList.toggle('open', menuOpen);
    document.getElementById('mobile-overlay').classList.toggle('open', menuOpen);
    const btn = document.getElementById('hamburger-btn');
    btn.classList.toggle('active', menuOpen);
    btn.setAttribute('aria-expanded', String(menuOpen));
    document.body.style.overflow = menuOpen ? 'hidden' : '';
  }

  function closeMenu() {
    menuOpen = false;
    ['mobile-menu', 'mobile-overlay'].forEach(id => document.getElementById(id).classList.remove('open'));
    const btn = document.getElementById('hamburger-btn');
    btn.classList.remove('active');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  // ─── API HELPERS ───
  function getToken() { return localStorage.getItem(TOKEN_KEY); }
  function getRefreshToken() { return localStorage.getItem(REFRESH_KEY); }

  // FIX: сохраняем оба токена
  function setTokens(access, refresh) {
    if (access) localStorage.setItem(TOKEN_KEY, access);
    if (refresh) localStorage.setItem(REFRESH_KEY, refresh);
  }
  function setToken(t) { localStorage.setItem(TOKEN_KEY, t); }

  // FIX: удаляем оба токена при логауте
  function removeToken() {
    localStorage.removeItem(TOKEN_KEY);
    localStorage.removeItem(REFRESH_KEY);
  }

  function normalizeReferralCode(code) {
    return (code || '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 32);
  }

  function getStoredReferralCode() {
    return normalizeReferralCode(localStorage.getItem(REF_KEY) || currentReferralCode);
  }

  // FIX: функция обновления токена с защитой от параллельных вызовов
  async function tryRefreshToken() {
    // Если уже идёт refresh — возвращаем тот же промис (все ждут одного результата)
    if (isRefreshing) return refreshPromise;

    const refreshToken = getRefreshToken();
    if (!refreshToken) return false;

    isRefreshing = true;
    // FIX: единый промис — параллельные 401 ждут его и не создают второй запрос
    refreshPromise = (async () => {
      try {
        const res = await fetch(API_BASE + '/auth/refresh', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ refresh_token: refreshToken })
        });
        if (res.ok) {
          const data = await res.json().catch(() => ({}));
          if (data.access_token) {
            // FIX: сохраняем новые токены (rotation: бэкенд может вернуть новый refresh)
            setTokens(data.access_token, data.refresh_token || refreshToken);
            return true;
          }
        }
        // FIX: 401/403 или сеть → удаляем оба токена, выходим
        removeToken();
        doLogout();
        return false;
      } catch {
        removeToken();
        doLogout();
        return false;
      } finally {
        isRefreshing = false;
        refreshPromise = null;
      }
    })();

    return refreshPromise;
  }

  // FIX: apiFetch с интерцептором 401 → refresh → повтор запроса
  async function apiFetch(endpoint, opts = {}) {
    const t = getToken();
    const headers = { 'Content-Type': 'application/json', ...(opts.headers || {}) };
    if (t) headers['Authorization'] = 'Bearer ' + t;

    const res = await fetch(API_BASE + endpoint, { ...opts, headers });

    // FIX: перехватываем 401, но НЕ для /auth/refresh (избегаем бесконечной рекурсии)
    if (res.status === 401 && !endpoint.includes('/auth/refresh')) {
      const refreshed = await tryRefreshToken();
      if (refreshed) {
        // FIX: повторяем исходный запрос с обновлённым токеном
        const newToken = getToken();
        const newHeaders = { 'Content-Type': 'application/json', ...(opts.headers || {}) };
        if (newToken) newHeaders['Authorization'] = 'Bearer ' + newToken;
        const retryRes = await fetch(API_BASE + endpoint, { ...opts, headers: newHeaders });
        const retryData = await retryRes.json().catch(() => ({}));
        return { ok: retryRes.ok, status: retryRes.status, data: retryData };
      }
      // refresh провалился — возвращаем исходный 401 без повторной попытки
      const data = await res.json().catch(() => ({}));
      return { ok: false, status: 401, data };
    }

    const data = await res.json().catch(() => ({}));
    return { ok: res.ok, status: res.status, data };
  }

  function showAlert(id, type, msg) {
    const el = document.getElementById(id + '-alert');
    if (!el) return;
    el.className = 'alert ' + type;
    el.textContent = msg;
  }

  function normalizeEmail(value) { return value.trim().toLowerCase(); }

  function getEmailValidationError(email) {
    const blockedDomains = new Set(['example.com', 'example.net', 'example.org', 'test.com', 'localhost']);
    const basicEmailRe = /^[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}$/i;
    if (!email) return 'Введите email';
    if (!basicEmailRe.test(email) || email.includes('..')) return 'Введите корректный email';
    const [localPart, domain] = email.split('@');
    if (!localPart || localPart.length > 64 || email.length > 254) return 'Введите корректный email';
    if (blockedDomains.has(domain) || domain.endsWith('.local')) return 'Введите действующий email';
    return '';
  }

  // ─── AUTH ───
  async function doRegister() {
    const btn = document.getElementById('btn-register');
    const email = normalizeEmail(document.getElementById('reg-email').value);
    const password = document.getElementById('reg-password').value;
    const emailError = getEmailValidationError(email);
    if (!email || !password) return showAlert('reg', 'error', 'Заполните все поля');
    if (emailError) return showAlert('reg', 'error', emailError);
    if (password.length < 8) return showAlert('reg', 'error', 'Пароль минимум 8 символов');
    btn.disabled = true; btn.textContent = 'Создаём аккаунт...';
    try {
      const { ok, data } = await apiFetch('/auth/register', {
        method: 'POST',
        body: JSON.stringify({
          email, password,
          referral_code: getStoredReferralCode(),
          client_referral_id: getReferralClientId()
        })
      });
      if (ok) {
        showAlert('reg', 'success', data.message || 'Письмо подтверждения отправлено. Проверьте почту.');
        document.getElementById('reg-password').value = '';
        // FIX: если бэкенд сразу вернул токены после регистрации — авторизуем
        if (data.access_token) {
          setTokens(data.access_token, data.refresh_token || null);
          setTimeout(async () => {
            closeModal('login');
            await loadUserData();
            openProfileModal(currentSub);
          }, 1500);
        }
      } else {
        showAlert('reg', 'error', data.detail || data.message || 'Ошибка регистрации');
      }
    } catch { showAlert('reg', 'error', 'Ошибка сети. Попробуйте позже.'); }
    finally { btn.disabled = false; btn.textContent = 'Создать аккаунт'; }
  }

  async function doLogin() {
    const btn = document.getElementById('btn-login');
    const email = normalizeEmail(document.getElementById('login-email').value);
    const password = document.getElementById('login-password').value;
    const emailError = getEmailValidationError(email);
    if (!email || !password) return showAlert('login', 'error', 'Заполните все поля');
    if (emailError) return showAlert('login', 'error', emailError);
    btn.disabled = true; btn.textContent = 'Входим...';
    try {
      const { ok, data } = await apiFetch('/auth/login', {
        method: 'POST',
        body: JSON.stringify({ email, password })
      });
      if (ok && data.access_token) {
        // FIX: сохраняем оба токена
        setTokens(data.access_token, data.refresh_token || null);
        closeModal('login');
        await loadUserData();
        // FIX: если пользователь пришёл из startPayment → открываем оплату после логина
        if (currentPlan) {
          openModal('payment');
          const plan = PLANS[currentPlan] || PLANS['1m'];
          const desc = document.getElementById('pay-desc');
          if (desc) {
            desc.textContent = '';
            const text = document.createTextNode('Тариф: ');
            const strong = document.createElement('strong');
            strong.textContent = plan.label;
            desc.appendChild(text);
            desc.appendChild(strong);
          }
          const a = document.getElementById('payment-alert');
          if (a) { a.className = 'alert'; a.textContent = ''; }
          const btn2 = document.getElementById('btn-lava');
          if (btn2) { btn2.disabled = false; btn2.textContent = '💳 Оплатить картой / СБП'; }
          isPaymentPending = false;
        } else {
          openProfileModal(currentSub);
        }
      } else {
        showAlert('login', 'error', data.detail || data.message || 'Неверный email или пароль');
      }
    } catch { showAlert('login', 'error', 'Ошибка сети. Попробуйте позже.'); }
    finally { btn.disabled = false; btn.textContent = 'Войти'; }
  }

  // ─── PROFILE MODAL ───
  function openProfileModal(sub) {
    const emailEl = document.getElementById('profile-email');
    emailEl.textContent = currentUser?.email || currentUser?.tg_username || '';

    const activeBlock = document.getElementById('profile-active-block');
    const inactiveBlock = document.getElementById('profile-inactive-block');
    if (sub && sub.active) {
      activeBlock.style.display = 'block';
      inactiveBlock.style.display = 'none';
      document.getElementById('profile-plan-badge').textContent = sub.plan_name || '';
      document.getElementById('profile-expires').textContent =
        sub.expires_at ? new Date(sub.expires_at).toLocaleDateString('ru-RU') : '—';
      document.getElementById('profile-sub-url').value = sub.subscription_url || '';
    } else {
      activeBlock.style.display = 'none';
      inactiveBlock.style.display = 'block';
    }
    openModal('profile');
  }

  async function copyText(text, alertId, successMsg) {
    try {
      await navigator.clipboard.writeText(text);
      showAlert(alertId, 'success', successMsg);
    } catch {
      try {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.focus(); ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showAlert(alertId, 'success', successMsg);
      } catch {
        showAlert(alertId, 'error', 'Не удалось скопировать. Скопируйте вручную.');
      }
    }
  }

  async function copySubUrl() {
    const val = document.getElementById('profile-sub-url').value;
    if (!val) return;
    await copyText(val, 'profile-copy', 'Скопировано!');
  }

  async function copyReferralLink() {
    const val = document.getElementById('ref-link').value;
    if (!val) return;
    await copyText(val, 'ref', 'Реферальная ссылка скопирована');
  }

  // FIX: doLogout удаляет оба токена
  function doLogout() {
    removeToken();
    currentUser = null; currentSub = null;
    updateNavState(null, null);
  }

  function captureReferralCode() {
    const params = new URLSearchParams(window.location.search);
    const fromQuery = normalizeReferralCode(params.get('ref') || params.get('start') || '');
    if (fromQuery) {
      currentReferralCode = fromQuery;
      localStorage.setItem(REF_KEY, fromQuery);
    } else {
      currentReferralCode = getStoredReferralCode();
    }
    if (fromQuery && params.get('email_verified') !== '1') {
      params.delete('ref'); params.delete('start');
      const query = params.toString();
      history.replaceState(null, '', window.location.pathname + (query ? '?' + query : '') + window.location.hash);
    }
  }

  async function loadUserData() {
    if (!getToken()) return false;
    try {
      const { ok, status, data } = await apiFetch('/user/me');
      if (ok) {
        currentUser = data;
        const sub = await loadSubscription();
        currentSub = sub;
        updateNavState(data, sub);
        return true;
      } else if (status === 401) {
        removeToken();
        if (tg && tg.initData) return await doTgAuth();
      } else {
        removeToken();
      }
    } catch { removeToken(); }
    return false;
  }

  async function loadSubscription() {
    try {
      const { ok, data } = await apiFetch('/user/subscription');
      return ok ? data : null;
    } catch { return null; }
  }

  async function loadReferralData() {
    const authBox = document.getElementById('ref-auth-box');
    const linkBox = document.getElementById('ref-link-box');
    if (!authBox || !linkBox) return;
    if (!getToken()) {
      authBox.style.display = 'block'; linkBox.style.display = 'none'; return;
    }
    try {
      const { ok, data } = await apiFetch('/user/referrals');
      if (!ok) throw new Error('referrals failed');
      authBox.style.display = 'none'; linkBox.style.display = 'block';
      document.getElementById('ref-link').value = data.link || '';
      document.getElementById('ref-total').textContent = data.total ?? 0;
      document.getElementById('ref-signup').textContent = data.signup_granted ?? 0;
      document.getElementById('ref-paid').textContent = data.paid_granted ?? 0;
      const blocked = document.getElementById('ref-blocked');
      if (blocked) blocked.textContent = data.same_ip_blocked ?? 0;
    } catch {
      authBox.style.display = 'block'; linkBox.style.display = 'none';
    }
  }

  function updateNavState(user, sub) {
    const out = document.getElementById('nav-auth-out');
    const inn = document.getElementById('nav-auth-in');
    if (user) {
      out.style.display = 'none'; inn.classList.add('visible');
      document.getElementById('nav-username').textContent = user.tg_username || user.email || 'Профиль';
      document.getElementById('nav-sub-badge').textContent = sub && sub.active ? sub.plan_name : 'Нет подписки';
      loadReferralData();
    } else {
      out.style.display = ''; inn.classList.remove('visible');
      loadReferralData();
    }
  }

  // ─── PAYMENT ───
  function startPayment(planKey) {
    currentPlan = planKey;
    // FIX: незарегистрированный пользователь → открываем логин, не показываем ошибку
    if (!getToken()) {
      openModal('login');
      setTimeout(() => {
        showAlert('login', 'error', 'Войдите или зарегистрируйтесь, чтобы оформить подписку');
      }, 100);
      return;
    }

    const plan = PLANS[planKey] || PLANS['1m'];
    const desc = document.getElementById('pay-desc');
    if (desc) {
      desc.textContent = '';
      const text = document.createTextNode('Тариф: ');
      const strong = document.createElement('strong');
      strong.textContent = plan.label;
      desc.appendChild(text);
      desc.appendChild(strong);
    }
    const a = document.getElementById('payment-alert');
    if (a) { a.className = 'alert'; a.textContent = ''; }
    const btn = document.getElementById('btn-lava');
    if (btn) { btn.disabled = false; btn.textContent = '💳 Оплатить картой / СБП'; }
    isPaymentPending = false;
    openModal('payment');
  }

  async function doLavaPayment() {
    // FIX: если токен пропал к моменту нажатия — редиректим на логин
    if (!getToken()) {
      closeModal('payment');
      openModal('login');
      return;
    }
    if (isPaymentPending) return;
    isPaymentPending = true;
    const btn = document.getElementById('btn-lava');
    btn.disabled = true; btn.textContent = 'Создаём счёт...';
    try {
      const { ok, data } = await apiFetch('/payment/create', {
        method: 'POST',
        body: JSON.stringify({ plan: currentPlan })
      });
      if (ok && data.payment_url) {
        if (tg && tg.openLink) {
          tg.openLink(data.payment_url);
        } else {
          window.open(data.payment_url, '_blank');
        }
        closeModal('payment');
      } else {
        showAlert('payment', 'error', data.detail || data.message || 'Ошибка платежа. Попробуйте позже.');
        btn.disabled = false; btn.textContent = '💳 Оплатить картой / СБП';
        isPaymentPending = false;
      }
    } catch {
      showAlert('payment', 'error', 'Ошибка соединения. Попробуйте позже.');
      btn.disabled = false; btn.textContent = '💳 Оплатить картой / СБП';
      isPaymentPending = false;
    }
  }

  // ─── FAQ ───
  function toggleFaq(btn) {
    const item = btn.parentElement;
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => {
      i.classList.remove('open');
      i.querySelector('.faq-q').setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }

  // ─── INIT ───
  document.addEventListener('DOMContentLoaded', async () => {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    captureReferralCode();

    const params = new URLSearchParams(window.location.search);
    if (params.get('email_verified') === '1') {
      openModal('login');
      showAlert('login', 'success', 'Email подтверждён. Теперь можно войти.');
      history.replaceState(null, '', window.location.pathname);
    }

    const hasToken = !!getToken();
    const hasRefresh = !!getRefreshToken();
    const isTgApp = tg && !!tg.initData;

    if (hasToken) {
      loadUserData();
    } else if (hasRefresh) {
      // FIX: есть refresh, но нет access → сразу обновляем перед loadUserData
      const refreshed = await tryRefreshToken();
      if (refreshed) loadUserData();
    } else if (isTgApp) {
      doTgAuth();
    }

    loadReferralData();
  });
</script>
</body>
</html>